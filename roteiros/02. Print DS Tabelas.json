esperar(1)
printscreen(pasta="C:/prints/ds_tabela", nome_arquivo="PRINT_DS_TABELA_[1515_tabelas1.TABELA]",
            formato="png", sobrescrever=true,
            x=1926, y=6, largura=1894, altura=2143, info="Print Estrutura CDS View")

teclado_atalho("ctrl+w", info="Fecha ABA")

