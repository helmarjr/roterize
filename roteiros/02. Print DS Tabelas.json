-- Roteiro para Printar Tabelas Datasphere

mouse(x=3333, y=42, acao="clicar_esquerdo", info="Foco no EDGE")

secao("Prepara primeira URL")

teclado_atalho("ctrl+t", info="Nova ABA")

teclado_digitar("https://valedevdatasphere.us10.hcs.cloud.sap/dwaas-core/index.html#/databuilder&/db/VALE_S4H_ING/[1515_tabelas1.DS_TABELA]", info="Cola nome CDSView")

teclado_pressionar("enter", info="Localizar")

secao("Prepara segunda URL")

teclado_atalho("ctrl+t", info="Nova ABA")

teclado_digitar("https://valedevdatasphere.us10.hcs.cloud.sap/dwaas-core/index.html#/databuilder&/db/VALE_S4H_ING/[1515_tabelas2.DS_TABELA]", info="Cola nome CDSView")

teclado_pressionar("enter", info="Localizar")

secao("Prepara terceira URL")

teclado_atalho("ctrl+t", info="Nova ABA")

