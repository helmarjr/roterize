printscreen(pasta="C:/prints/estrutura", nome_arquivo="PRINT_CDS_VIEW_ESTRUTURA_{py}",
            formato="png", sobrescrever=true,
            x=9, y=180, largura=1900, altura=1900, info="Print Estrutura CDS View")
