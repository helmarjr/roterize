mouse(x=1000, y=900, acao="clicar_esquerdo", info="Foco texto")

mouse(x=1000, y=900, acao="clicar_segurar", info="seleciona texto 1/3")

mouse(x=400, y=190, acao="mover", info="seleciona texto 2/3")

mouse(x=400, y=190, acao="clicar_soltar", info="seleciona texto 3/3")

